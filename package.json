{
  "name": "@baking-bad/free-route-tezos-x",
  "version": "0.3.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "description": "SDK for free-route swaps on Tezos X — turn any ERC20/XTZ swap into ready-to-sign Tezos operations, signed from the Michelson side.",
  "license": "MIT",
  "author": "Baking Bad",
  "keywords": [
    "tezos",
    "tezos-x",
    "free-route",
    "swap",
    "dex",
    "erc20",
    "objkt",
    "nft",
    "marketplace",
    "michelson",
    "etherlink",
    "defi"
  ],
  "homepage": "https://github.com/3route/free-route-tezos-x#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3route/free-route-tezos-x.git"
  },
  "bugs": {
    "url": "https://github.com/3route/free-route-tezos-x/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./michelson": {
      "types": "./dist/michelson/index.d.ts",
      "default": "./dist/michelson/index.js"
    },
    "./evm": {
      "types": "./dist/evm/index.d.ts",
      "default": "./dist/evm/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "tsx --test src/tests/*/*.test.ts",
    "test:e2e": "tsx --test scripts/e2e/*.test.ts",
    "setup": "tsx scripts/shared/setup.ts",
    "example-buy:michelson": "tsx scripts/michelson/example-buy.ts",
    "example-buy:evm": "tsx scripts/evm/example-buy.ts",
    "bridge:evm": "tsx scripts/evm/bridge.ts",
    "bridge:michelson": "tsx scripts/michelson/bridge.ts",
    "addresses:michelson": "tsx scripts/michelson/addresses.ts",
    "addresses:evm": "tsx scripts/evm/addresses.ts",
    "compile:fa2": "ligo compile contract contracts/fa2_nft.mligo --michelson-format json -o contracts/fa2_nft.json",
    "deploy:fa2": "tsx scripts/shared/deploy-fa2.ts",
    "deploy:objkt": "tsx scripts/shared/deploy-objkt.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  },
  "peerDependencies": {
    "@taquito/michel-codec": "^24.2.0",
    "@taquito/michelson-encoder": "^24.2.0",
    "@taquito/taquito": "^24.2.0",
    "@taquito/utils": "^24.2.0"
  },
  "peerDependenciesMeta": {
    "@taquito/michel-codec": {
      "optional": true
    },
    "@taquito/taquito": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@taquito/michel-codec": "~24.3.0",
    "@taquito/michelson-encoder": "~24.3.0",
    "@taquito/signer": "~24.3.0",
    "@taquito/taquito": "~24.3.0",
    "@taquito/utils": "~24.3.0",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "viem": "^2.53.1"
  }
}

{
  "name": "3route-tezosx",
  "version": "0.1.0",
  "type": "module",
  "description": "Prepare 3route swaps (ERC20/XTZ -> ERC20/XTZ) on Tezos X from the Michelson side as ready-to-sign Tezos ops; native-XTZ output auto-forwards to the Michelson address. Compose marketplace ops (objkt) into one atomic group.",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "tsx --test src/tests/*.test.ts",
    "setup": "tsx scripts/setup.ts",
    "example": "tsx scripts/example-buy.ts"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@taquito/michelson-encoder": "~24.2.0",
    "@taquito/signer": "~24.2.0",
    "@taquito/taquito": "~24.2.0",
    "@taquito/utils": "~24.2.0",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@taquito/rpc": "~24.2.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}

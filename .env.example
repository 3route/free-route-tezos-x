# Copy to `.env` and fill. Keys the SDK example reads (sdk/index.ts).
# Tezos X previewnet. No inline comments after '=' — the reader takes everything after it as the value.

# Buyer tz1 secret key (edsk...). Signs the op-group; its EVM alias is derived from this tz1 in code.
BUYER_TZ1_SK=
# objkt v4 marketplace address (KT1...).
OBJKT_MARKETPLACE=

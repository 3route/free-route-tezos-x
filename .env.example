# Copy to `.env` and fill the keys. Tezos X previewnet. No inline comments after '='.
# Grouped: common (shared), for example (buy), for setup/originate.

# ─────────── common ───────────
MICHELSON_RPC=https://michelson.previewnet.tezosx.nomadic-labs.com
EVM_RPC=https://evm.previewnet.tezosx.nomadic-labs.com
TZKT_EXPLORER=https://previewnet.tezosx.tzkt.io
FREE_ROUTE_API=https://3route-tezos-x-previewnet.dipdup.net
# FREE_ROUTE_API_KEY=   # only for a hosted free-route server; local dev is keyless
OBJKT_MARKETPLACE=
TEST_FA2=

# ─────────── for example (buy) ───────────
# Buyer Michelson secret key (edsk...). Signs the op-group; its EVM alias is derived in code.
# Per-run knobs are passed on the CLI: ASK_ID, PAY_SYMBOL (price is read from the ask).
BUYER_MICHELSON_SK=

# ─────────── for setup / originate ───────────
# Seller Michelson secret key (must differ from the buyer); its address is derived in code.
SELLER_MICHELSON_SK=

# Copy to `.env.local`. All values have working previewnet defaults in lib/config.ts —
# only override if you point at a different deployment / 3route server.

# 3route server base URL — used SERVER-SIDE by the /api/v6.1 proxy (avoids browser CORS).
RS_API=http://127.0.0.1:3000

# Public previewnet wiring (browser-visible). Defaults live in lib/config.ts.
